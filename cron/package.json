{
  "name": "TMDB",
  "version": "1.0.0",
  "description": " the movie database fetch data from tmdb",
  "main": "index.js",
  "scripts": {
    "db:migrate": "sequelize --options-path ./src/schema/.sequelizerc db:migrate",
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "nodemon build/index.js",
    "prestart": "npm run build",
    "test": "echo \"No tests specified\" && exit 1"
  },
  "dependencies": {
    "axios": "1.7.9",
    "axios-retry": "4.5.0",
    "cron": "3.5.0",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "ioredis": "5.4.2",
    "morgan": "1.10.0",
    "pg": "8.13.1",
    "pg-hstore": "2.3.4",
    "sequelize": "6.37.5"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/morgan": "1.9.9",
    "@types/node": "22.10.3",
    "@types/pg": "8.11.10",
    "@types/sequelize": "4.28.20",
    "nodemon": "3.1.9",
    "sequelize-typescript": "2.1.6",
    "ts-node": "10.9.2",
    "tsx": "3.0.0",
    "typescript": "5.7.2"
  },
  "author": "",
  "license": "ISC"
}
